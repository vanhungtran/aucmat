% Generated by hand to match the current source file.
\name{simulate_auc_correlation}
\alias{simulate_auc_correlation}
\title{Simulate repeated X vectors for a fixed y and record AUC and correlation}
\usage{
simulate_auc_correlation(
  y,
  target_auc,
  n_sim = 10000,
  positive = NULL,
  seed = NULL,
  cor_method = c("pearson", "spearman", "kendall"),
  keep_x = FALSE
)
}
\arguments{
  \item{y}{Binary outcome vector. Accepted inputs are logical, numeric 0/1,
  factor, or character with exactly two non-missing classes.}

  \item{target_auc}{One target AUC or a numeric vector of target AUC values in
  [0, 1].}

  \item{n_sim}{Number of simulations. Default 10000.}

  \item{positive}{Optional positive class label when \code{y} is a factor or
  character vector. By default, the second factor level is treated as the
  positive class.}

  \item{seed}{Optional random seed.}

  \item{cor_method}{Correlation method passed to \code{stats::cor()}. One of
  \code{"pearson"}, \code{"spearman"}, or \code{"kendall"}. Default
  \code{"pearson"}.}

  \item{keep_x}{Logical. If \code{TRUE}, also return the simulated \code{X}
  values as a matrix with one column per simulation. Default \code{FALSE}.}
}
\value{
A list with components:
\item{results}{A data.frame with one row per simulation per requested
target and columns \code{target_auc}, \code{sim}, \code{auc}, and
\code{correlation}.}
\item{target_auc}{The requested target AUC value(s).}
\item{mean_shift}{A data.frame with columns \code{target_auc} and
\code{mean_shift}. For \code{target_auc = 1}, \code{mean_shift} is reported as
\code{Inf} because perfect separation is handled as a special case rather than
a finite normal shift.}
\item{n_sim}{Number of simulations performed per target AUC.}
\item{x_matrix}{Optional matrix of simulated predictors if \code{keep_x = TRUE}
and \code{length(target_auc) == 1}.}
\item{x_matrix_list}{Optional named list of simulated predictor matrices if
\code{keep_x = TRUE} and multiple target AUC values are supplied.}
}
\description{
For a fixed binary outcome vector \code{y}, repeatedly simulate continuous
predictors \code{X} from two normal distributions with equal variance and a mean
separation chosen so that the theoretical AUC equals \code{target_auc}. For each
simulation, the function calculates the empirical AUC and the correlation
between \code{y} and \code{X}. When \code{target_auc = 1}, the function uses a
perfect-separation special case so that each simulated predictor yields
\code{auc = 1} while preserving within-class variation.
}
\examples{
set.seed(1)
y <- rbinom(1000, size = 1, prob = 0.3)
sim <- simulate_auc_correlation(y, target_auc = c(0.8, 0.9, 1), n_sim = 100)
head(sim$results)
aggregate(auc ~ target_auc, data = sim$results, mean)
}