% Generated by hand to match the current source file.
\name{generate_auc_cor_vector}
\alias{generate_auc_cor_vector}
\title{Generate a continuous score vector for target AUC and correlation}
\usage{
generate_auc_cor_vector(
  y,
  target_auc,
  target_cor,
  positive = NULL,
  auc_unattainable = c("nearest", "error"),
  cor_unattainable = c("nearest", "error"),
  seed = NULL,
  shuffle_within_class = TRUE,
  lambda_bounds = c(-8, 8),
  lambda_grid_n = 401,
  cor_tol = 1e-06
)
}
\arguments{
  \item{y}{Binary outcome vector. Accepted inputs are logical, numeric 0/1,
  factor, or character with exactly two non-missing classes.}

  \item{target_auc}{Target empirical AUC in [0, 1].}

  \item{target_cor}{Target Pearson correlation between \code{y} and the generated
  score vector.}

  \item{positive}{Optional positive class label when \code{y} is a factor or
  character vector. By default, the second factor level is treated as the
  positive class.}

  \item{auc_unattainable}{One of \code{"nearest"} or \code{"error"}. Passed to
  \code{generate_auc_vector()} when the requested AUC is not exactly attainable
  on the finite-sample grid.}

  \item{cor_unattainable}{One of \code{"nearest"} or \code{"error"}. If the
  requested correlation is outside the achievable range of the monotone
  transform family, \code{"nearest"} returns the closest match and warns, while
  \code{"error"} stops.}

  \item{seed}{Optional seed used only when constructing the base AUC-matched
  score vector.}

  \item{shuffle_within_class}{Logical. Passed to \code{generate_auc_vector()}.}

  \item{lambda_bounds}{Numeric length-2 vector giving the search interval for
  the Box-Cox transform parameter. Default \code{c(-8, 8)}.}

  \item{lambda_grid_n}{Number of grid points used to bracket the correlation
  search before local refinement. Default \code{401}.}

  \item{cor_tol}{Numeric tolerance used to decide whether the requested
  correlation was achieved. Default \code{1e-6}.}
}
\value{
A list with components:
\item{x}{Numeric score vector with the same length as \code{y}. Missing values
in \code{y} are propagated as \code{NA} in \code{x}.}
\item{requested_auc}{The requested AUC.}
\item{requested_cor}{The requested correlation.}
\item{achieved_auc}{The empirical AUC achieved by \code{x}.}
\item{achieved_cor}{The Pearson correlation achieved by \code{x}.}
\item{lambda}{The fitted Box-Cox transform parameter.}
\item{cor_range}{Length-2 numeric vector with the approximate minimum and
maximum correlations achievable over \code{lambda_bounds}.}
\item{base_vector}{The object returned by \code{generate_auc_vector()} before the
monotone transform was applied.}
}
\description{
Construct a numeric score vector for a binary outcome with an empirical AUC
matched exactly when attainable, then tune a strictly increasing Box-Cox
transform so the Pearson correlation between \code{y} and \code{x} matches a
requested value as closely as possible without changing the AUC.
}
\details{
The method relies on the fact that empirical AUC is rank-based, while Pearson
correlation is value-based.

First, a base score vector is constructed so that its empirical AUC matches the
requested target exactly when that target is attainable on the finite-sample
grid.

Second, the base score is shifted to positive values and passed through a
strictly increasing Box-Cox transform. Because the transform is monotone, it
preserves the rank ordering of the base score and therefore preserves the AUC.
However, it changes the spacing of the score values, so the Pearson
correlation with the binary outcome changes.

The function searches over the Box-Cox parameter to find the correlation
closest to the requested target. Not every \code{(AUC, correlation)} pair is
achievable for a fixed \code{y}, because the transform can only change spacing,
not ordering.
}
\examples{
set.seed(1)
y <- rbinom(200, size = 1, prob = 0.3)
out <- generate_auc_cor_vector(y, target_auc = 0.8, target_cor = 0.45)
c(out$achieved_auc, out$achieved_cor)
}